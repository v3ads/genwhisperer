# ─── Database ─────────────────────────────────────────────────────────────────
NEON_DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ─── Auth / Sessions ──────────────────────────────────────────────────────────
# 32+ char random secret for JWT signing
JWT_SECRET=REPLACE_WITH_32_CHAR_RANDOM_SECRET

# ─── Encryption ───────────────────────────────────────────────────────────────
# 64 hex chars (32 bytes) for AES-256-GCM encryption of user API keys
ENCRYPTION_SECRET=REPLACE_WITH_64_HEX_CHARS

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:5173
ADMIN_EMAIL=vipaymanshalaby@gmail.com

# ─── OpenRouter (Platform key for free-trial users) ───────────────────────────
OPENROUTER_PLATFORM_KEY=sk-or-v1-REPLACE_ME

# ─── Brevo (Transactional email) ──────────────────────────────────────────────
BREVO_API_KEY=REPLACE_ME
BREVO_SENDER_NAME=Geny
BREVO_SENDER_EMAIL=support@genwhisperer.com

# ─── GetResponse (Marketing / subscriber sync) ────────────────────────────────
GETRESPONSE_API_KEY=REPLACE_ME
# Leave blank on first run — the app will auto-create the "GenWhisperer" list
GETRESPONSE_LIST_ID=
